<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Innovi Wear Store</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Global site stylesheet (consolidated & advanced) -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand" href="/">INNOVI</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Category">Category</a>
                    </li>
                </ul>

                <!-- Navbar Search -->
                <div class="navbar-search">
                    <input type="text"
                           id="navbarSearchInput"
                           class="navbar-search-input"
                           placeholder="Search products..."
                           autocomplete="off">
                    <button class="navbar-search-btn" id="navbarSearchBtn">
                        <i class="fas fa-search"></i>
                    </button>
                    <div id="searchResultsDropdown" class="search-results-dropdown"></div>
                </div>

                @* <!-- DARK MODE -->
                <button id="themeToggle" class="theme-toggle">🌙</button> 

                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Cart"><i class="fas fa-shopping-cart"></i> Cart</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="/Account/Profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/Account/MyOrders">My Orders</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Register">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h4>INNOVI</h4>
                    <p>Innovative fashion for modern lifestyles</p>
                </div>
                <div class="col-md-4">
                    <h4>Quick Links</h4>
                    <ul class="list-unstyled">
                        <li><a href="/Home/Category">Categories</a></li>
                        <li><a href="/Account/Profile">My Account</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h4>Contact</h4>
                    <p>Email: mahmoudramadan3lisayed@gmail.com</p>
                    <p>Phone: 01015145347</p>
                </div>
            </div>
            <div class="text-center mt-4">
                <p>&copy; 2024 Innovi Wear Store - All Rights Reserved</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Product data from server (passed from view)
        let allProducts = [];

        // Function to load products from server
        function loadProducts() {
            $.ajax({
                url: '/Home/GetAllProducts',
                type: 'GET',
                success: function(products) {
                    allProducts = products;
                    console.log('Products loaded:', allProducts.length);
                },
                error: function() {
                    console.error('Failed to load products');
                }
            });
        }

        // Search function
        function performSearch() {
            const searchTerm = $('#navbarSearchInput').val().toLowerCase().trim();
            const dropdown = $('#searchResultsDropdown');

            if (searchTerm === '') {
                dropdown.removeClass('show').empty();
                return;
            }

            // Filter products
            const filteredProducts = allProducts.filter(product =>
                product.name.toLowerCase().includes(searchTerm) ||
                product.category.toLowerCase().includes(searchTerm) ||
                product.description.toLowerCase().includes(searchTerm)
            );

            // Display results
            if (filteredProducts.length > 0) {
                let html = '';
                filteredProducts.slice(0, 5).forEach(product => {
                    html += `
                        <div class="search-result-item" onclick="window.location.href='/Home/ProductDetails/${product.id}'">
                            <img src="${product.imageUrl || 'https://via.placeholder.com/50'}" class="search-result-img" onerror="this.src='https://via.placeholder.com/50'">
                            <div class="search-result-info">
                                <div class="search-result-name">${product.name}</div>
                                <div class="search-result-category">${product.category}</div>
                            </div>
                            <div class="search-result-price">$${parseFloat(product.price).toFixed(2)}</div>
                        </div>
                    `;
                });

                if (filteredProducts.length > 5) {
                    html += `
                        <div class="search-result-item" onclick="window.location.href='/Home/SearchResults?q=${encodeURIComponent(searchTerm)}'">
                            <div style="text-align: center; width: 100%; color: var(--primary);">
                                <i class="fas fa-search"></i> View all ${filteredProducts.length} results
                            </div>
                        </div>
                    `;
                }

                dropdown.html(html).addClass('show');
            } else {
                dropdown.html(`
                    <div class="search-no-results">
                        <i class="fas fa-box-open"></i><br>
                        No products found for "${searchTerm}"
                    </div>
                `).addClass('show');
            }
        }

        // Debounce function for better performance
        let debounceTimer;
        function debounceSearch() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(performSearch, 300);
        }

        // Event listeners
        $(document).ready(function() {
            loadProducts();

            $('#navbarSearchInput').on('keyup', debounceSearch);
            $('#navbarSearchBtn').on('click', function() {
                const searchTerm = $('#navbarSearchInput').val();
                if (searchTerm) {
                    window.location.href = `/Home/SearchResults?q=${encodeURIComponent(searchTerm)}`;
                }
            });

            // Close dropdown when clicking outside
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.navbar-search').length) {
                    $('#searchResultsDropdown').removeClass('show');
                }
            });

            // Search on Enter key
            $('#navbarSearchInput').on('keypress', function(e) {
                if (e.which === 13) {
                    const searchTerm = $(this).val();
                    if (searchTerm) {
                        window.location.href = `/Home/SearchResults?q=${encodeURIComponent(searchTerm)}`;
                    }
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
 *@


