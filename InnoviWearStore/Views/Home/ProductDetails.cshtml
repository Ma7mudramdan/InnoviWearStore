@model InnoviWearStore.Models.Product
@{
    ViewData["Title"] = Model.Name;

    if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
    {
        Layout = "_AdminLayout";
    }
}

<div class="container py-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded-3 shadow" alt="@Model.Name" onerror="this.src='https://via.placeholder.com/600x400?text=@Model.Name'">
        </div>
        <div class="col-md-6">
            <h1 class="display-5 fw-bold mb-3">@Model.Name</h1>
            <p class="text-muted mb-3">
                <i class="fas fa-tag"></i> Category: @Model.Category
            </p>

            @if (!string.IsNullOrEmpty(Model.Size))
            {
                <p class="text-muted mb-3">
                    <i class="fas fa-ruler"></i> Size: @Model.Size
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.Color))
            {
                <p class="text-muted mb-3">
                    <i class="fas fa-palette"></i> Color: @Model.Color
                </p>
            }

            <h2 class="text-primary mb-4">$@Model.Price.ToString("F2")</h2>

            @if (Model.StockQuantity > 0)
            {
                <p class="text-success mb-3">
                    <i class="fas fa-check-circle"></i> In Stock (@Model.StockQuantity available)
                </p>
            }
            else
            {
                <p class="text-danger mb-3">
                    <i class="fas fa-times-circle"></i> Out of Stock
                </p>
            }

            <p class="mb-4">@Model.Description</p>

            @if (User.Identity.IsAuthenticated && Model.StockQuantity > 0 && User.IsInRole("User"))
            {
                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-3">
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <label class="form-label">Quantity:</label>
                            <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control" style="width: 80px;" />
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary-gradient px-4 py-2">
                                <i class="fas fa-shopping-cart"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                </form>
            }
            else if (!User.Identity.IsAuthenticated)
            {
                <a href="/Account/Login" class="btn btn-primary-gradient px-4 py-2 mt-3">
                    <i class="fas fa-sign-in-alt"></i> Login to Purchase
                </a>
            }
           @if (User.Identity.IsAuthenticated && User.IsInRole("User"))
            {
            <div class="mt-4 pt-3 border-top">
                <a href="/" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Continue Shopping
                </a>
            </div>
            }
        </div>
    </div>
</div>

<style>
    .btn-primary-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        transition: transform 0.3s, box-shadow 0.3s;
    }

        .btn-primary-gradient:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102,126,234,0.4);
            color: white;
        }
</style>