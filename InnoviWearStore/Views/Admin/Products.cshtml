@model IEnumerable<InnoviWearStore.Models.Product>
@{
    ViewData["Title"] = "Products Management";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="~/css/Products.css" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>
        <i class="fas fa-box"></i> Products
    </h3>
    <a href="/Admin/CreateProduct" class="btn-add">
        <i class="fas fa-plus"></i> Add New Product
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="product-table">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th style="width: 60px;">ID</th>
                <th style="width: 80px;">Image</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock</th>
                <th style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Id</td>
                    <td>
                 
                        <a href="/Home/ProductDetails/@product.Id" style="text-decoration: none; color: inherit; display: flex; align-items: center; gap: 10px;">
                        <img src="@product.ImageUrl" class="product-image" onerror="this .src='https://via.placeholder.com/50'">
                        </a>
                    </td>
                    <td>@product.Name</td>
                    <td>@product.Category</td>
                    <td>$@product.Price.ToString("F2")</td>
                    <td>
                        @if (product.StockQuantity > 20)
                        {
                            <span class="stock-high"><i class="fas fa-check-circle"></i> @product.StockQuantity</span>
                        }
                        else if (product.StockQuantity > 0)
                        {
                            <span class="stock-low"><i class="fas fa-exclamation-triangle"></i> @product.StockQuantity</span>
                        }
                        else
                        {
                            <span class="stock-out"><i class="fas fa-times-circle"></i> Out of stock</span>
                        }
                    </td>
                    <td>
                        <div class="action-buttons">
                            <a href="/Admin/EditProduct/@product.Id" class="btn-edit btn">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <form asp-action="DeleteProduct" asp-route-id="@product.Id" method="post" onsubmit="return confirm('Are you sure you want to delete @product.Name?')" style="display: inline;">
                                <button type="submit" class="btn-delete btn">
                                    <i class="fas fa-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </td>
                    
                </tr>

            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-3 mt-3">
        <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
        <p class="text-muted">No products found. Click "Add New Product" to get started.</p>
    </div>
}