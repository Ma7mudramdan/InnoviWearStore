@model IEnumerable<InnoviWearStore.Models.User>
@{
    ViewData["Title"] = "Users Management";
    Layout = "_AdminLayout";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<link rel="stylesheet" href="~/css/Users.css" />

<h3 class="mb-4">Users</h3>

<div class="user-table">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Email</th>
                <th>Name</th>
                <th>Phone</th>
                <th>Registered</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var roles = userRoles?.ContainsKey(user.Id) == true ? userRoles[user.Id] : new List<string>();
                var isAdmin = roles.Contains("Admin");
                <tr>
                    <td>@user.Email</td>
                    <td>@user.FirstName @user.LastName</td>
                    <td>@user.PhoneNumber</td>
                    <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>
                        @if (isAdmin)
                        {
                            <span class="role-badge role-admin">Admin</span>
                        }
                        else
                        {
                            <span class="role-badge role-user">User</span>
                        }
                    </td>
                    <td>
                        @if (!isAdmin)
                        {
                            <form asp-action="MakeAdmin" method="post" style="display: inline;">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('Make @user.Email an admin?')">
                                    <i class="fas fa-crown"></i> Make Admin
                                </button>
                            </form>
                        }
                        else if (user.Email != "admin@innovi.com")
                        {
                            <form asp-action="RemoveAdmin" method="post" style="display: inline;">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Remove admin rights from @user.Email?')">
                                    <i class="fas fa-user"></i> Remove Admin
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>