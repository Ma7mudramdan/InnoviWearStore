@model IEnumerable<InnoviWearStore.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon primary">
            <i class="fas fa-box"></i>
        </div>
        <div class="stat-info">
            <h3>@ViewBag.TotalProducts</h3>
            <p>Total Products</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon success">
            <i class="fas fa-shopping-cart"></i>
        </div>
        <div class="stat-info">
            <h3>@ViewBag.TotalOrders</h3>
            <p>Total Orders</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon warning">
            <i class="fas fa-users"></i>
        </div>
        <div class="stat-info">
            <h3>@ViewBag.TotalUsers</h3>
            <p>Total Users</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon info">
            <i class="fas fa-dollar-sign"></i>
        </div>
        <div class="stat-info">
            <h3>$@ViewBag.TotalRevenue.ToString("N0")</h3>
            <p>Total Revenue</p>
        </div>
    </div>
</div>

<div class="recent-orders">
    <h4><i class="fas fa-clock"></i> Recent Orders</h4>

    @if (!Model.Any())
    {
        <p class="text-muted text-center">No orders yet.</p>
    }
    else
    {
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Order #</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.User?.Email</td>
                        <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td>$@order.TotalAmount.ToString("F2")</td>
                        <td>
                            <span class="badge @(order.Status.ToLower() == "cancelled" ? "bg-danger" : $"badge-{order.Status.ToLower()}")">@order.Status</span>
                        </td>
                        <td>
                            <a href="/Admin/OrderDetails/@order.Id" class="btn btn-sm btn-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>