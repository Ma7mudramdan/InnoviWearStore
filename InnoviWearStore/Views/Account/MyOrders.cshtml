                                <i class="far fa-clock"></i>
                                @order.OrderDate.ToString("hh:mm tt")
                            </span>
                        </div>
                        <div style="display: flex; gap: 15px; align-items: center; flex-wrap: wrap;">
                            <span class="order-status status-@order.Status.ToLower()">
                                @if (order.Status == "Completed")
                                {
                                    <i class="fas fa-check-circle"></i>
                                }
                                else if (order.Status == "Pending")
                                {
                                    <i class="fas fa-hourglass-half"></i>
                                }
                                else if (order.Status == "Processing")
                                {
                                    <i class="fas fa-cog fa-spin"></i>
                                }
                                else if (order.Status == "Shipped")
                                {
                                    <i class="fas fa-truck"></i>
                                }
                                else
                                {
                                    <i class="fas fa-times-circle"></i>
                                }
                                @order.Status
                            </span>
                            <span class="order-total">
                                $@order.TotalAmount.ToString("F2")
                            </span>
                        </div>
                    </div>

                    <div class="order-body">
                        @if (order.OrderItems != null && order.OrderItems.Any())
                        {
                            <div class="table-responsive">
                                <table class="items-table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th style="width: 100px;">Quantity</th>
                                            <th style="width: 120px;">Unit Price</th>
                                            <th style="width: 120px;">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in order.OrderItems)
                                        {
                                            <tr>
                                                <td>
                                                    <div class="product-cell">
                                                        @if (item.Product?.ImageUrl != null)
                                                        {
                                                            <img src="@item.Product.ImageUrl" class="product-thumb" alt="@item.Product.Name" onerror="this.src='https://via.placeholder.com/55'">
                                                        }
                                                        else
                                                        {
                                                            <div class="product-thumb" style="background: #e2e8f0; display: flex; align-items: center; justify-content: center;">
                                                                <i class="fas fa-image" style="color: #94a3b8; font-size: 1.2rem;"></i>
                                                            </div>
                                                        }
                                                        <div>
                                                            <div class="product-name">@(item.Product?.Name ?? "Product not available")</div>
                                                            <div class="product-meta">
                                                                @if (!string.IsNullOrEmpty(item.Product?.Category))
                                                                {
                                                                    <span><i class="fas fa-tag"></i> @item.Product.Category</span>
                                                                }
                                                                @if (!string.IsNullOrEmpty(item.Product?.Size))
                                                                {
                                                                    <span class="ms-2"><i class="fas fa-ruler"></i> @item.Product.Size</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center fw-bold">@item.Quantity</td>
                                                <td>$@item.UnitPrice.ToString("F2")</td>
                                                <td class="text-primary fw-bold">$@((item.Quantity * item.UnitPrice).ToString("F2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center py-3">No items found for this order.</p>
                        }

                        @if (!string.IsNullOrEmpty(order.ShippingAddress))
                        {
                            <div class="shipping-info">
                                <div class="shipping-title">
                                    <i class="fas fa-truck"></i> Shipping Information
                                </div>
                                <div class="shipping-address">
                                    <i class="fas fa-map-marker-alt"></i> @order.ShippingAddress
                                </div>
                                @if (!string.IsNullOrEmpty(order.PhoneNumber))
                                {
                                    <div class="shipping-address" style="margin-top: 8px;">
                                        <i class="fas fa-phone"></i> @order.PhoneNumber
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(order.PaymentMethod))
                                {
                                    <div class="shipping-address" style="margin-top: 8px;">
                                        <i class="fas fa-credit-card"></i> Paid via: @order.PaymentMethod
                                    </div>
                                }
                            </div>
                        }

                        <div class="order-actions">
                            <button class="btn-reorder" onclick="reorderItems(@order.Id, this)">
                                <i class="fas fa-redo"></i> Reorder All
                            </button>

                            <button class="btn-track" onclick="trackOrder(@order.Id, '@order.Status')">
                                <i class="fas fa-map-marked-alt"></i> Track Order
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Reorder function - adds all items from order to cart
    function reorderItems(orderId, button) {
        // Show loading state on button
        const btn = $(button);
        const originalText = btn.html();
        btn.html('<i class="fas fa-spinner fa-spin"></i> Adding...').prop('disabled', true);

        // Make AJAX call to add items to cart
        $.ajax({
            url: '/Cart/ReorderOrder',
            type: 'POST',
            data: { orderId: orderId },
            success: function(response) {
                if (response.success) {
                    showNotification('success', response.message);
                    setTimeout(function() {
                        window.location.href = '/Cart';
                    }, 1000);
                } else {
                    showNotification('error', response.message);
                    btn.html(originalText).prop('disabled', false);
                }
            },
            error: function() {
                showNotification('error', 'Failed to add items to cart. Please try again.');
                btn.html(originalText).prop('disabled', false);
            }
        });
    }

    // Track order function
    function trackOrder(orderId, status) {
        let message = '';
        let icon = '';

        switch(status) {
            case 'Completed':
                icon = '✅';
                message = `Order #ORDER-${orderId.toString().padStart(6, '0')}\n\n📦 Your order has been delivered successfully!\n🎉 Thank you for shopping with Innovi.\n\n⭐ We hope you enjoyed your purchase!`;
                break;
            case 'Processing':
                icon = '⚙️';
                message = `Order #ORDER-${orderId.toString().padStart(6, '0')}\n\n⚙️ Your order is being processed.\n🕐 Estimated processing time: 1-2 business days.\n📧 You will receive an email when it ships.`;
                break;
            case 'Shipped':
                icon = '🚚';
                message = `Order #ORDER-${orderId.toString().padStart(6, '0')}\n\n🚚 Your order is on the way!\n📍 Estimated delivery: 2-4 business days.\n🔑 You can track your package with tracking number.`;
                break;
            case 'Pending':
                icon = '⏳';
                message = `Order #ORDER-${orderId.toString().padStart(6, '0')}\n\n⏳ Your order is pending confirmation.\n📝 We're reviewing your order details.\n📧 You will receive updates shortly.`;
                break;
            case 'Cancelled':
                icon = '❌';
                message = `Order #ORDER-${orderId.toString().padStart(6, '0')}\n\n❌ This order has been cancelled.\n📞 Please contact support if you have questions.`;
                break;
            default:
                icon = '📋';
                message = `Order #ORDER-${orderId.toString().padStart(6, '0')}\n\n📋 Status: ${status}\n📞 Please contact support for more information.`;
        }

        alert(`${icon} Order Tracking\n\n${message}`);
    }

    // Show notification function
    function showNotification(type, message) {
        const notification = $('<div>')
            .addClass(`toast-notification ${type}`)
            .html(`<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'}"></i><span>${message}</span>`);

        $('body').append(notification);

        setTimeout(() => {
            notification.css('animation', 'slideOutRight 0.3s ease');
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    // Scroll to orders section
    function scrollToOrders() {
        const firstOrder = $('.order-card').first();
        if (firstOrder.length) {
            $('html, body').animate({
                scrollTop: firstOrder.offset().top - 100
            }, 500);
        }
    }

    // Add animation keyframes if not exists
    if (!document.querySelector('#orderStyles')) {
        const style = document.createElement('style');
        style.id = 'orderStyles';
        style.textContent = `
            .fa-spin {
                animation: fa-spin 2s infinite linear;
            }
            @@keyframes fa-spin {
                0% { transform: rotate(0deg); }
                100% { transform: rotate(360deg); }
            }
        `;
        document.head.appendChild(style);
    }
</script>